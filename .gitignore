# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
node_modules
.next
.env*.local

# Archived pre-rebuild stack — kept on disk + in git history, out of new commits.
legacy/

# INWW source templates (originals, .doc, sample-filled) stay out of git.
# Anchored to root so the blank tokenised templates under public/templates/ ARE committed.
/templates/

# OCR engine assets — large + derivable; regenerated by `npm run setup:ocr` (prebuild).
/public/ocr/*
!/public/ocr/.gitkeep

# local secrets (never commit)
*.secret

# supabase CLI local state
supabase/.temp
supabase/.branches
